# ============================================
# AFRO QUEENS - Variables d'environnement
# ============================================
# Copiez ce fichier en .env.local et remplissez vos vraies valeurs

# ----- STRIPE -----
# Récupérez ces clés sur https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_PUBLISHABLE
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_SECRETE

# ----- WHATSAPP -----
# Remplacez par votre numéro WhatsApp (format international sans +)
NEXT_PUBLIC_WHATSAPP_NUMBER=33700000000

# ----- SITE -----
NEXT_PUBLIC_SITE_URL=https://afroqueens.com
NEXT_PUBLIC_SITE_NAME=Afro Queens

# ----- EMAIL (optionnel - pour le formulaire de contact) -----
# Utilisez Resend, SendGrid ou Nodemailer
EMAIL_FROM=contact@afroqueens.com
EMAIL_TO=contact@afroqueens.com
